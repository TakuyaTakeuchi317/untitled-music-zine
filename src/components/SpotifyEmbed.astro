---
interface Props {
  url: string;
  compact?: boolean;
  label?: string;
}

const { url, compact = false, label } = Astro.props;

// Normalize URL: ensure it's an embed URL
const embedUrl = url.includes('/embed/')
  ? url
  : url.replace('https://open.spotify.com/', 'https://open.spotify.com/embed/');

const height = compact ? '152' : '352';
---

<figure class="spotify-figure my-8 not-prose">
  {label && (
    <figcaption class="font-mono text-[10px] uppercase tracking-[0.2em] text-stone-400 mb-3">
      {label}
    </figcaption>
  )}
  <div class="spotify-wrapper">
    <iframe
      src={embedUrl}
      width="100%"
      height={height}
      allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
      loading="lazy"
      title={label ?? 'Spotify Player'}
    ></iframe>
  </div>
</figure>
